# OpenAI 兼容协议配置
# 可填 OpenAI 官方、DeepSeek、通义千问、Moonshot、智谱等任意走 OpenAI 协议的服务
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
CHEFLY_MODEL=gpt-4o-mini

# Web 服务
CHEFLY_HOST=0.0.0.0
CHEFLY_PORT=8000


# 日志
CHEFLY_LOG_LEVEL=INFO
CHEFLY_LOG_DIR=logs
CHEFLY_LOG_TO_CONSOLE=1
CHEFLY_LOG_MAX_BYTES=5242880
CHEFLY_LOG_BACKUP_COUNT=5