# OpenAI 兼容协议配置
# 可填 OpenAI 官方、DeepSeek、通义千问、Moonshot、智谱等任意走 OpenAI 协议的服务
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
XIAOCHU_MODEL=gpt-4o-mini

# Web 服务
XIAOCHU_HOST=0.0.0.0
XIAOCHU_PORT=8000


# 日志
XIAOCHU_LOG_LEVEL=INFO
XIAOCHU_LOG_DIR=logs
XIAOCHU_LOG_TO_CONSOLE=1
XIAOCHU_LOG_MAX_BYTES=5242880
XIAOCHU_LOG_BACKUP_COUNT=5